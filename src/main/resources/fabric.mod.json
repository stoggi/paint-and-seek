{
	"schemaVersion": 1,
	"id": "paintandseek",
	"version": "${version}",
	"name": "PaintAndSeek",
	"description": "Hide-and-seek where hiders paint their skin in-game to blend into the environment.",
	"authors": [
		"stoggi"
	],
	"contact": {
		"homepage": "https://modrinth.com/mod/paint-and-seek",
		"sources": "https://github.com/stoggi/paint-and-seek"
	},
	"license": "MIT",
	"icon": "assets/paintandseek/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			{
				"value": "io.paintandseek.PaintAndSeek",
				"adapter": "kotlin"
			}
		],
		"client": [
			{
				"value": "io.paintandseek.client.PaintAndSeekClient",
				"adapter": "kotlin"
			}
		],
		"fabric-datagen": [
			{
				"value": "io.paintandseek.client.PaintAndSeekDataGenerator",
				"adapter": "kotlin"
			}
		]
	},
	"mixins": [
		"paintandseek.mixins.json",
		{
			"config": "paintandseek.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~26.2",
		"java": ">=25",
		"fabric-api": "*",
		"fabric-language-kotlin": "*"
	}
}